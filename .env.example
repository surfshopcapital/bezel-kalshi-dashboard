# =============================================================================
# Bezel-Kalshi Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
# Local docker: postgresql://bezel_user:bezel_password@localhost:5432/bezel_kalshi
# Neon / Supabase / PlanetScale: get from your provider dashboard
DATABASE_URL="postgresql://bezel_user:bezel_password@localhost:5432/bezel_kalshi"

# ---------------------------------------------------------------------------
# Kalshi API
# ---------------------------------------------------------------------------
# Base URL for the Kalshi v2 trading API
KALSHI_BASE_URL="https://api.elections.kalshi.com/trade-api/v2"

# Optional: your Kalshi API key (found in Account → API Keys on kalshi.com)
# Required for authenticated endpoints. Some public endpoints work without it.
KALSHI_API_KEY=""

# ---------------------------------------------------------------------------
# Bezel
# ---------------------------------------------------------------------------
# Base URL for Bezel markets site (used by the scraper)
BEZEL_BASE_URL="https://markets.getbezel.com"

# ---------------------------------------------------------------------------
# Cron / Job Security
# ---------------------------------------------------------------------------
# Random secret used to authenticate cron job API routes.
# Generate a strong random string, e.g.: openssl rand -hex 32
# Vercel Cron passes this automatically via Authorization: Bearer header.
CRON_SECRET="replace-with-a-strong-random-secret"

# ---------------------------------------------------------------------------
# Next.js Public Variables (available in browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# App Configuration
# ---------------------------------------------------------------------------
NODE_ENV="development"

# Log level: error | warn | info | debug
LOG_LEVEL="info"

# Set to "false" to show the Playwright browser window when debugging scraping
PLAYWRIGHT_HEADLESS="true"
